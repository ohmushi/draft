# Variables d'environnement Draft
# En prod (Dokploy) : remplir ces valeurs dans l'onglet "Environment" de l'application Compose.
# `postgres` est le hostname du service Postgres défini dans docker-compose.yml.

# Postgres
POSTGRES_USER=draft
POSTGRES_PASSWORD=changeme
POSTGRES_DB=draft
DATABASE_URL=postgres://draft:changeme@postgres:5432/draft

# MinIO (PWA /studio — désactivé pour l'instant)
# MINIO_ROOT_USER=
# MINIO_ROOT_PASSWORD=
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=draft-media

# GitHub (push d'entrées depuis la PWA — désactivé pour l'instant)
# GITHUB_TOKEN=
# GITHUB_OWNER=
# GITHUB_REPO=