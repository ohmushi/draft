# Variables d'environnement Draft
# En prod (Dokploy) : remplir ces valeurs dans l'onglet "Environment" de l'application Compose.
# `postgres` est le hostname du service Postgres défini dans docker-compose.yml.

# Postgres
POSTGRES_USER=draft
POSTGRES_PASSWORD=changeme
POSTGRES_DB=draft
# URL utilisée par Docker Compose (hostname = nom du service).
# Pour dev hors Docker (npm run dev), créer un .env.local avec :
# DATABASE_URL=postgres://draft:changeme@localhost:5432/draft
DATABASE_URL=postgres://draft:changeme@postgres:5432/draft

# MinIO — stockage des médias (photos de la PWA /studio)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
# Endpoint interne (hostname du service Docker) utilisé par le client MinIO
MINIO_ENDPOINT=http://minio:9000
# URL publique base pour les médias servis dans le MDX (sans slash final)
# En dev local : http://localhost:9000
# En prod : https://minio.mon-serveur.com
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=draft-media

# GitHub (push d'entrées depuis la PWA — désactivé pour l'instant)
# GITHUB_TOKEN=
# GITHUB_OWNER=
# GITHUB_REPO=
